rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // 1. Global Safety Net
    match /{document=**} {
      allow read, write: if false;
    }

    // 2. Helper Functions
    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }

    function isSignedIn() {
      return request.auth != null;
    }

    function isEmailVerified() {
      return isSignedIn() && request.auth.token.email_verified == true;
    }

    function isValidNewsletter(data) {
      return data.id is string && data.id.size() <= 128
        && data.title is string && data.title.size() <= 200
        && data.month is string && data.month.size() <= 50
        && data.pdfUrl is string && data.pdfUrl.size() <= 500
        && data.thumbnailUrl is string && data.thumbnailUrl.size() <= 500
        && data.publishedAt is string && data.publishedAt.size() <= 20
        && (data.isLatest == true || data.isLatest == false);
    }

    // 3. Newsletters Collection rules
    match /newsletters/{newsletterId} {
      // Publicly readable so visitors can see publications
      allow read, get, list: if true;
      
      // Creating or updating requires being signed in
      allow create: if isSignedIn() 
        && isValidId(newsletterId)
        && isValidNewsletter(request.resource.data);
        
      allow update: if isSignedIn()
        && isValidId(newsletterId)
        && isValidNewsletter(request.resource.data)
        && request.resource.data.id == resource.data.id; // ID immutability
        
      allow delete: if isSignedIn();
    }
  }
}
